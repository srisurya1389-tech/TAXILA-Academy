rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ponytail: the admin panel now gates access with a plain username/
    // password check in admin/index.html instead of Firebase Auth, so there
    // is no request.auth to verify here anymore — this is fully open to
    // any reader/writer who has the Firestore config (which is public in
    // the site's client-side code). Upgrade path: move back to Firebase
    // Auth (Email/Password or Google) and gate with request.auth if the
    // registration data (names/phones/emails) needs real protection again.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
